INTERLIS 2.4;

MODEL DemoSpatialTarget AT "https://example.org/ilitransformer" VERSION "2026-06-24" =
  DOMAIN
    Coord2 = COORD 2460000.000 .. 2870000.000,
                   1045000.000 .. 1310000.000;

  TOPIC Catalog =
    CLASS Station =
      Identifier : TEXT*40;
      Name : TEXT*80;
      Geometry : Coord2;
    END Station;
  END Catalog;
END DemoSpatialTarget.
