INTERLIS 2.4;

MODEL DemoTarget AT "https://example.org/ilitransformer" VERSION "2026-06-25" =
  DOMAIN
    Coord = COORD 0.0 .. 50.0,
            0.0 .. 90.0;

  TOPIC Catalog =
    BASKET OID AS INTERLIS.UUIDOID;
    OID AS INTERLIS.UUIDOID;

    CLASS Station =
      BfsNr : 0 .. 9999;
      Name : TEXT*80;
      Geometry : Coord;
    END Station;
  END Catalog;
END DemoTarget.
