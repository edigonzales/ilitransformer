INTERLIS 2.4;

MODEL DemoJdbcSpatialSource AT "https://example.org/ilitransformer" VERSION "2026-06-24" =
  DOMAIN
    Coord2 = COORD 2460000.000 .. 2870000.000,
                   1045000.000 .. 1310000.000;

  TOPIC Data =
    CLASS Station =
      identifier : TEXT*40;
      name : TEXT*80;
      geom : Coord2;
    END Station;
  END Data;
END DemoJdbcSpatialSource.
