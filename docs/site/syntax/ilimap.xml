<!DOCTYPE language SYSTEM "language.dtd">
<!-- ilimap mapping DSL syntax highlighting for Pandoc -->
<language version="1" kateversion="5.0" name="ilimap" section="Sources" extensions="*.ilimap" license="MIT">
<highlighting>

  <list name="keywords">
    <item>mapping</item>
    <item>v2</item>
    <item>job</item>
    <item>input</item>
    <item>output</item>
