INTERLIS 2.4;

MODEL ShpWriterTest (en)
  AT "http://test.ilitransformer.ch" VERSION "2026-06-25" =
  TOPIC Data =
    BASKET OID AS INTERLIS.UUIDOID;
    OID AS INTERLIS.STANDARDOID;

    DOMAIN
      LV95Coord = COORD 2480000.000 .. 2850000.000, 1070000.000 .. 1310000.000;
      LV95MultiCoord = MULTICOORD 2480000.000 .. 2850000.000, 1070000.000 .. 1310000.000;

    STRUCTURE Extra =
      Info: TEXT*40;
    END Extra;

    CLASS Station =
      Name: MANDATORY TEXT*60;
      BfsNr: 0 .. 9999;
      Aktiv: BOOLEAN;
      Zusatz: Extra;
      Geometrie: MANDATORY LV95Coord;
    END Station;

    CLASS Strecke =
      Name: TEXT*60;
      Linie: POLYLINE WITH (STRAIGHTS) VERTEX LV95Coord;
    END Strecke;

    CLASS Flaeche =
      Name: TEXT*60;
      Perimeter: SURFACE WITH (STRAIGHTS) VERTEX LV95Coord WITHOUT OVERLAPS > 0.001;
    END Flaeche;

    CLASS TwoGeom =
      P1: LV95Coord;
      P2: LV95Coord;
    END TwoGeom;

    CLASS Typen =
      Name: TEXT*60;
      Zahl: 0.00 .. 999.99;
      Flag: BOOLEAN;
      Status: (aktiv, inaktiv, stillgelegt);
      Datum: INTERLIS.XMLDate;
      Geometrie: LV95Coord;
    END Typen;

    CLASS MehrPunkt =
      Name: TEXT*60;
      Lage: LV95MultiCoord;
    END MehrPunkt;

    CLASS Tabelle =
      Name: TEXT*60;
      Zahl: 0 .. 9999;
      Flag: BOOLEAN;
    END Tabelle;

  END Data;
END ShpWriterTest.
