TRANSFER INTERLIS1;

MODEL Ili1SurfaceAreaTestModel

  DOMAIN
    LV95Coord = COORD2 2480000.000 1070000.000
                        2850000.000 1310000.000;

  TOPIC TestTopic =

    TABLE SurfaceClass =
      NBIdent: TEXT*12;
      Perimeter: SURFACE WITH (STRAIGHTS, ARCS) VERTEX LV95Coord
        WITHOUT OVERLAPS > 0.001;
      IDENT NBIdent;
    END SurfaceClass;

    TABLE AreaClass =
      NBIdent: TEXT*12;
      Geometrie: AREA WITH (STRAIGHTS, ARCS) VERTEX LV95Coord
        WITHOUT OVERLAPS > 0.001;
      IDENT NBIdent;
    END AreaClass;

  END TestTopic.

END Ili1SurfaceAreaTestModel.

FORMAT FREE;

CODE
  BLANK = DEFAULT, UNDEFINED = DEFAULT, CONTINUE = DEFAULT;
  TID = ANY;
END.
