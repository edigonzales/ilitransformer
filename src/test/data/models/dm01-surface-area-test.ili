INTERLIS 2.4;

MODEL Dm01SurfaceAreaTestModel (de)
  AT "http://test.ili-transformer.ch" VERSION "2026-06-07" =
  TOPIC TestTopic =
    BASKET OID AS INTERLIS.STANDARDOID;
    OID AS INTERLIS.STANDARDOID;

    DOMAIN
      LV95Coord = COORD 2480000.000 .. 2850000.000, 1070000.000 .. 1310000.000;

    CLASS SurfaceClass =
      NBIdent: MANDATORY TEXT*12;
      Perimeter: SURFACE WITH (STRAIGHTS, ARCS) VERTEX LV95Coord WITHOUT OVERLAPS > 0.001;
    END SurfaceClass;

    CLASS AreaClass =
      NBIdent: MANDATORY TEXT*12;
      Geometrie: AREA WITH (STRAIGHTS, ARCS) VERTEX LV95Coord WITHOUT OVERLAPS > 0.001;
    END AreaClass;

  END TestTopic;
END Dm01SurfaceAreaTestModel.
