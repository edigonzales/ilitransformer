INTERLIS 2.4;

MODEL P5Model (en)
  AT "http://test.ilitransformer.ch" VERSION "2026-06-07" =
  TOPIC P5Topic =
    BASKET OID AS INTERLIS.UUIDOID;
    OID AS INTERLIS.STANDARDOID;

    CLASS SourceClass =
      Name: MANDATORY TEXT*60;
      Anzahl: 0 .. 9999;
      Aktiv: BOOLEAN;
    END SourceClass;

    CLASS TargetClass =
      Label: MANDATORY TEXT*60;
      Size: 0 .. 9999;
      Enabled: BOOLEAN;
    END TargetClass;

  END P5Topic;
END P5Model.
