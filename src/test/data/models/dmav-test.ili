INTERLIS 2.4;

MODEL DmavTestModel (de)
  AT "http://test.ili-transformer.ch" VERSION "2026-06-07" =
  TOPIC Fixpunkte =
    BASKET OID AS INTERLIS.UUIDOID;
    OID AS INTERLIS.UUIDOID;

    DOMAIN
      Zuverlaessigkeit = BOOLEAN;
      Versicherungsart = (Stein, Kunststoffzeichen, Bolzen, Rohr, Pfahl, Kreuz, unversichert, weitere);
      LFPArt = (LFP3, Hilfsfixpunkt);
      Grenzpunktfunktion = (keine, Grenzpunkt, Hoheitsgrenzpunkt);
      HAlignment = (Left, Center, Right);
      VAlignment = (Top, Cap, Half, Baseline, Bottom);

    STRUCTURE Textposition =
      Position: MANDATORY 0.0 .. 9999999.0;
      Orientierung: MANDATORY 0.0 .. 400.0;
      HReferenzpunkt: HAlignment;
      VReferenzpunkt: VAlignment;
    END Textposition;

    CLASS LFP3Nachfuehrung =
      NBIdent: MANDATORY TEXT*12;
      Identifikator: MANDATORY TEXT*12;
      Beschreibung: MANDATORY TEXT*60;
      GueltigerEintrag: MANDATORY INTERLIS.XMLDateTime;
    END LFP3Nachfuehrung;

    CLASS LFP3 =
      NBIdent: MANDATORY TEXT*12;
      Nummer: MANDATORY TEXT*12;
      LFPArt: MANDATORY LFPArt;
      Geometrie: MANDATORY TEXT*30;
      Hoehengeometrie: 0.0 .. 9999.9;
      Lagegenauigkeit: MANDATORY 0.001 .. 7.000;
      IstLagezuverlaessig: MANDATORY Zuverlaessigkeit;
      Hoehengenauigkeit: 0.001 .. 7.000;
      IstHoehenzuverlaessig: Zuverlaessigkeit;
      Punktzeichen: MANDATORY Versicherungsart;
      Grenzpunktfunktion: MANDATORY Grenzpunktfunktion;
      AktiverUnterhalt: MANDATORY BOOLEAN;
      SymbolOri: 0.0 .. 400.0;
      Textposition: BAG {0..*} OF Textposition;
    END LFP3;

    ASSOCIATION Entstehung_LFP3 =
      Entstehung -- {1} LFP3Nachfuehrung;
      entstehender_LFP3 -- {0..*} LFP3;
    END Entstehung_LFP3;

  END Fixpunkte;
END DmavTestModel.
