INTERLIS 2.4;

MODEL DmavGeomTestModel (de)
  AT "http://test.ilitransformer.ch" VERSION "2026-06-07" =
  TOPIC Fixpunkte =
    BASKET OID AS INTERLIS.UUIDOID;
    OID AS INTERLIS.UUIDOID;

    DOMAIN
      LV95Coord = COORD 2480000.000 .. 2850000.000, 1070000.000 .. 1310000.000;

    CLASS LFP3 =
      NBIdent: MANDATORY TEXT*12;
      Nummer: MANDATORY TEXT*12;
      Geometrie: MANDATORY LV95Coord;
      Lagegenauigkeit: MANDATORY 0.0 .. 700.0;
    END LFP3;

  END Fixpunkte;
END DmavGeomTestModel.
