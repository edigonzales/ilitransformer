{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ILIMAP",
  "scopeName": "source.ilimap",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#arrow"
    },
    {
      "include": "#hashLiterals"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "arrow": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.ilimap",
          "match": "=>"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.ilimap",
          "match": "//.*$"
        },
        {
          "name": "comment.block.ilimap",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.ilimap",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.ilimap",
          "match": "\\bnull\\b"
        }
      ]
    },
    "hashLiterals": {
      "patterns": [
        {
          "name": "constant.other.hash-literal.ilimap",
          "match": "#[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.ilimap",
          "match": "\\b(?:mapping|v2|job|input|output|oid|basket|enum|defaults|rule|target|source|from|class|where|join|inner|left|identity|assign|bag|ref|association|role|required|create|loss|metadata)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.ilimap",
          "match": "\\b-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.ilimap",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.ilimap",
              "match": "\\\\."
            }
          ]
        }
      ]
    }
  }
}
